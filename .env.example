# ---------------------------------------------------------------------------
# Neon Serverless Postgres
# ---------------------------------------------------------------------------
# Connection string for your Neon database. Used by drizzle-orm/neon-http
# for standard queries and drizzle-orm/neon-serverless for the transactional
# booking flow (lib/db/transaction.ts).
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<database>?sslmode=require"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Required for deployments where the host isn't auto-detected (e.g. Cloudflare).
AUTH_TRUST_HOST="true"

# ---------------------------------------------------------------------------
# Google OAuth (Sign in with Google)
# ---------------------------------------------------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <your-app-url>/api/auth/callback/google
AUTH_GOOGLE_ID="replace-with-your-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-your-google-client-secret"

# ---------------------------------------------------------------------------
# Gmail SMTP (Forgot password emails)
# ---------------------------------------------------------------------------
# Use a Google Account App Password, not your normal password:
# https://myaccount.google.com/apppasswords (requires 2-Step Verification)
GMAIL_USER="replace-with-your-gmail-address"
GMAIL_APP_PASSWORD="replace-with-your-16-character-app-password"
